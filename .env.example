# ---------------------------------------------------------------------------
# Copier ce fichier vers .env (racine) et adapter les valeurs.
# En production : ne JAMAIS reutiliser les secrets de developpement.
# ---------------------------------------------------------------------------

NODE_ENV=development

# --- Base de donnees -------------------------------------------------------
DATABASE_URL="postgresql://change_rdc:change_rdc_dev@localhost:5432/change_rdc?schema=public"

# --- API -------------------------------------------------------------------
API_PORT=4000
# Origines autorisees pour le CORS, separees par des virgules.
CORS_ORIGINS="http://localhost:3000"

# --- JWT -------------------------------------------------------------------
# Generer avec : node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="remplacer-par-un-secret-aleatoire-de-48-octets-minimum"
JWT_REFRESH_SECRET="remplacer-par-un-autre-secret-aleatoire-different-du-premier"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"
# Cookie du refresh token : true obligatoire en production (HTTPS).
COOKIE_SECURE=false
# Laisser vide en developpement (cookie host-only). En production : votre domaine,
# ex. change-rdc.cd
COOKIE_DOMAIN=

# --- Google Identity Services ----------------------------------------------
# Console Google Cloud > API et services > Identifiants > ID client OAuth 2.0
# Laisser vide pour desactiver proprement le bouton "Continuer avec Google".
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Stockage des pieces jointes -------------------------------------------
# local | s3
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH="./storage"
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="change-rdc"
S3_ACCESS_KEY_ID="change_rdc"
S3_SECRET_ACCESS_KEY="change_rdc_dev"
S3_FORCE_PATH_STYLE=true

# --- Frontend --------------------------------------------------------------
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_GOOGLE_CLIENT_ID=""
