// Schema de la plateforme de change manuel RDC.
//
// Principes structurants :
//  - Toute ecriture metier est scopee par agence (multi-agences des le depart).
//  - Les montants sont en Decimal(20,4) : jamais de Float pour de la monnaie.
//    Le CDF a des montants nominaux eleves, d'ou la mantisse large.
//  - Rien n'est supprime physiquement : statuts + audit_logs.
//  - L'autorisation ne vient JAMAIS du fournisseur d'identite (cf. User.role).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  BCC
  CABISTE
  SUPERVISEUR
}

enum UserStatus {
  ACTIF
  SUSPENDU
  ARCHIVE
}

/// Provider ayant servi a *prouver l'identite*. N'a aucun effet sur le role.
enum AuthProvider {
  LOCAL
  GOOGLE
}

enum AgencyStatus {
  ACTIVE
  FERMEE
}

/// Devises gerees. CDF est la monnaie locale (devise de cotation) ; toutes
/// les autres sont des devises etrangeres cotees en CDF. Liste alignee sur
/// les cours publies par la BCC.
enum Currency {
  CDF
  USD
  EUR
  GBP
  CHF
  JPY
  CNY
  CAD
  AUD
  ZAR
  RWF
  UGX
  TZS
  ZMW
  BIF
  XAF
  AOA
  XDR
}

enum IdDocumentType {
  CARTE_ELECTEUR
  PASSEPORT
  PERMIS_CONDUIRE
  CARTE_SERVICE
  CARTE_REFUGIE
  AUTRE
}

/// Sens de l'operation du point de vue du bureau de change.
/// ACHAT  : le bureau achete la devise etrangere au client.
/// VENTE  : le bureau vend la devise etrangere au client.
enum TransactionType {
  ACHAT
  VENTE
}

enum TransactionStatus {
  EN_ATTENTE
  VALIDEE
  REJETEE
  ANNULEE
}

enum AttachmentKind {
  PIECE_IDENTITE
  JUSTIFICATIF
  BORDEREAU
  AUTRE
}

enum AlertType {
  SEUIL_DEPASSE
  FRACTIONNEMENT
  TAUX_HORS_BANDE
  CLIENT_SANS_PIECE
  OPERATIONS_REPETEES
  AUTRE
}

enum AlertSeverity {
  INFO
  MOYENNE
  HAUTE
  CRITIQUE
}

enum AlertStatus {
  OUVERTE
  EN_REVUE
  RESOLUE
  IGNOREE
}

enum AuditAction {
  CONNEXION
  CONNEXION_ECHOUEE
  DECONNEXION
  LIAISON_GOOGLE
  CREATION
  MODIFICATION
  SUPPRESSION
  VALIDATION
  REJET
  ANNULATION
  CONSULTATION
  EXPORT
  IMPRESSION_BORDEREAU
  OUVERTURE_CAISSE
  CLOTURE_CAISSE
}

enum CashSessionStatus {
  OUVERTE
  CLOTUREE
}

// ---------------------------------------------------------------------------
// Organisation
// ---------------------------------------------------------------------------

model Agency {
  id        String       @id @default(uuid()) @db.Uuid
  /// Code court utilise dans les references de transaction (ex. "GOM").
  code      String       @unique @db.VarChar(8)
  name      String       @db.VarChar(160)
  city      String       @db.VarChar(80)
  commune   String?      @db.VarChar(80)
  address   String?      @db.VarChar(255)
  phone     String?      @db.VarChar(32)
  /// Numero d'agrement BCC du bureau de change.
  licenseNo String?      @map("license_no") @db.VarChar(64)
  status    AgencyStatus @default(ACTIVE)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  users         User[]
  clients       Client[]
  transactions  Transaction[]
  exchangeRates ExchangeRate[]
  cashSessions  CashSession[]

  @@index([status])
  @@map("agencies")
}

model User {
  id           String       @id @default(uuid()) @db.Uuid
  fullName     String       @map("full_name") @db.VarChar(160)
  email        String       @unique @db.VarChar(190)
  /// Nul quand le compte n'a jamais defini de mot de passe (Google seul).
  passwordHash String?      @map("password_hash") @db.VarChar(255)
  authProvider AuthProvider @default(LOCAL) @map("auth_provider")
  googleId     String?      @unique @map("google_id") @db.VarChar(64)
  /// Source de verite de l'autorisation. Jamais alimente par Google.
  role         Role
  status       UserStatus   @default(ACTIF)
  phone        String?      @db.VarChar(32)
  /// Nul pour ADMIN et BCC : leur perimetre est national.
  agencyId     String?      @map("agency_id") @db.Uuid
  lastLoginAt  DateTime?    @map("last_login_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  agency Agency? @relation(fields: [agencyId], references: [id], onDelete: Restrict)

  refreshTokens      RefreshToken[]
  clientsCreated     Client[]        @relation("ClientCreatedBy")
  transactions       Transaction[]   @relation("TransactionOperator")
  transactionsReview Transaction[]   @relation("TransactionReviewer")
  ratesCreated       ExchangeRate[]  @relation("RateCreatedBy")
  attachments        Attachment[]    @relation("AttachmentUploadedBy")
  alertsResolved     Alert[]         @relation("AlertResolvedBy")
  auditLogs          AuditLog[]
  receiptsIssued     Receipt[]       @relation("ReceiptIssuedBy")
  cashSessions       CashSession[]   @relation("CashSessionOperator")

  @@index([role, status])
  @@index([agencyId])
  @@map("users")
}

/// Refresh tokens rotatifs. On stocke un hash SHA-256, jamais le token brut :
/// une fuite de la table ne permet pas de rejouer une session.
model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  /// Chaine de rotation : permet de detecter la reutilisation d'un token revoque.
  familyId  String    @map("family_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  userAgent String?   @map("user_agent") @db.VarChar(255)
  ip        String?   @db.VarChar(64)
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ---------------------------------------------------------------------------
// Clients
// ---------------------------------------------------------------------------

model Client {
  id             String         @id @default(uuid()) @db.Uuid
  agencyId       String         @map("agency_id") @db.Uuid
  firstName      String         @map("first_name") @db.VarChar(80)
  lastName       String         @map("last_name") @db.VarChar(80)
  /// Denormalise pour la recherche plein texte et les tris.
  fullName       String         @map("full_name") @db.VarChar(170)
  idDocumentType IdDocumentType @map("id_document_type")
  idDocumentNo   String         @map("id_document_no") @db.VarChar(64)
  nationality    String         @default("Congolaise (RDC)") @db.VarChar(80)
  birthDate      DateTime?      @map("birth_date") @db.Date
  phone          String?        @db.VarChar(32)
  address        String?        @db.VarChar(255)
  /// Personne politiquement exposee : declenche une vigilance renforcee.
  isPep          Boolean        @default(false) @map("is_pep")
  notes          String?        @db.Text
  createdById    String         @map("created_by_id") @db.Uuid
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  agency    Agency @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  createdBy User   @relation("ClientCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  transactions Transaction[]
  attachments  Attachment[]
  alerts       Alert[]

  /// Un meme numero de piece ne peut pas exister deux fois : c'est la cle
  /// d'identification du client au sens KYC.
  @@unique([idDocumentType, idDocumentNo], name: "uq_client_identity")
  @@index([agencyId])
  @@index([fullName])
  @@index([createdById])
  @@map("clients")
}

// ---------------------------------------------------------------------------
// Taux de change
// ---------------------------------------------------------------------------

/// Taux applicable sur une periode. On ne modifie jamais un taux passe :
/// on cloture (effectiveTo) et on en cree un nouveau, sinon les transactions
/// historiques deviennent incontrolables pour la BCC.
model ExchangeRate {
  id            String    @id @default(uuid()) @db.Uuid
  /// Nul = taux national applicable a toutes les agences.
  agencyId      String?   @map("agency_id") @db.Uuid
  baseCurrency  Currency  @map("base_currency")
  quoteCurrency Currency  @map("quote_currency")
  /// Prix auquel le bureau ACHETE 1 unite de baseCurrency, exprime en quoteCurrency.
  buyRate       Decimal   @map("buy_rate") @db.Decimal(20, 6)
  /// Prix auquel le bureau VEND 1 unite de baseCurrency, exprime en quoteCurrency.
  sellRate      Decimal   @map("sell_rate") @db.Decimal(20, 6)
  /// Taux de reference BCC du jour, pour controler l'ecart autorise.
  referenceRate Decimal?  @map("reference_rate") @db.Decimal(20, 6)
  effectiveFrom DateTime  @map("effective_from")
  effectiveTo   DateTime? @map("effective_to")
  createdById   String    @map("created_by_id") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")

  agency    Agency? @relation(fields: [agencyId], references: [id], onDelete: Cascade)
  createdBy User    @relation("RateCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  transactions Transaction[]

  @@index([baseCurrency, quoteCurrency, effectiveFrom])
  @@index([agencyId, effectiveTo])
  @@map("exchange_rates")
}

// ---------------------------------------------------------------------------
// Transactions
// ---------------------------------------------------------------------------

model Transaction {
  id       String @id @default(uuid()) @db.Uuid
  /// Reference metier lisible : TX-GOM-20260717-000042
  reference String @unique @db.VarChar(40)
  agencyId String @map("agency_id") @db.Uuid
  /// Le cabiste qui a saisi l'operation.
  operatorId String @map("operator_id") @db.Uuid
  clientId String @map("client_id") @db.Uuid

  type TransactionType

  fromCurrency Currency @map("from_currency")
  toCurrency   Currency @map("to_currency")
  /// Montant remis par le client, dans fromCurrency.
  fromAmount   Decimal  @map("from_amount") @db.Decimal(20, 4)
  /// Montant remis au client, dans toCurrency (net de commission).
  toAmount     Decimal  @map("to_amount") @db.Decimal(20, 4)
  /// Taux effectivement applique. Fige a la saisie : ne suit jamais le taux courant.
  appliedRate  Decimal  @map("applied_rate") @db.Decimal(20, 6)
  commission   Decimal  @default(0) @db.Decimal(20, 4)
  /// Contre-valeur en USD au moment de l'operation, pour les seuils AML
  /// et les statistiques agregees toutes devises confondues.
  usdEquivalent Decimal @map("usd_equivalent") @db.Decimal(20, 4)

  /// Taux ayant servi de base. Nul si le taux a ete saisi manuellement (derogation).
  exchangeRateId String? @map("exchange_rate_id") @db.Uuid

  /// Session de caisse a laquelle l'operation est rattachee. Nul si le cabiste
  /// n'a pas ouvert de caisse (le suivi de caisse est facultatif).
  cashSessionId String? @map("cash_session_id") @db.Uuid

  status          TransactionStatus @default(EN_ATTENTE)
  reviewedById    String?           @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?         @map("reviewed_at")
  reviewComment   String?           @map("review_comment") @db.Text

  /// Horodatage metier de l'operation au guichet (peut differer de createdAt).
  occurredAt DateTime @map("occurred_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  agency       Agency        @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  operator     User          @relation("TransactionOperator", fields: [operatorId], references: [id], onDelete: Restrict)
  reviewedBy   User?         @relation("TransactionReviewer", fields: [reviewedById], references: [id], onDelete: Restrict)
  client       Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  exchangeRate ExchangeRate? @relation(fields: [exchangeRateId], references: [id], onDelete: Restrict)
  cashSession  CashSession?  @relation(fields: [cashSessionId], references: [id], onDelete: SetNull)

  receipt     Receipt?
  attachments Attachment[]
  alerts      Alert[]

  @@index([agencyId, occurredAt])
  @@index([operatorId, occurredAt])
  @@index([clientId])
  @@index([status, occurredAt])
  @@index([occurredAt])
  @@index([cashSessionId])
  @@map("transactions")
}

/// Bordereau. Une ligne par transaction, numero unique et immuable.
/// Le PDF est regenere a l'identique depuis ces donnees : on stocke le
/// checksum pour prouver qu'un bordereau reimprime est bien le meme document.
model Receipt {
  id            String   @id @default(uuid()) @db.Uuid
  number        String   @unique @db.VarChar(40)
  transactionId String   @unique @map("transaction_id") @db.Uuid
  issuedById    String   @map("issued_by_id") @db.Uuid
  issuedAt      DateTime @default(now()) @map("issued_at")
  /// SHA-256 du payload canonique du bordereau.
  checksum      String   @db.VarChar(64)
  /// Nombre de reimpressions : une reimpression anormale est un signal de controle.
  printCount    Int      @default(0) @map("print_count")
  lastPrintedAt DateTime? @map("last_printed_at")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  issuedBy    User        @relation("ReceiptIssuedBy", fields: [issuedById], references: [id], onDelete: Restrict)

  @@index([issuedAt])
  @@map("receipts")
}

// ---------------------------------------------------------------------------
// Caisse
// ---------------------------------------------------------------------------

/// Session de caisse d'un cabiste sur une journee.
///
/// En debut de journee (facultatif), le cabiste declare les fonds qu'il a en
/// main par devise (openingBalances). Chaque operation rattachee alimente les
/// mouvements ; en fin de journee, le solde theorique par devise vaut
/// ouverture + entrees - sorties. Le cabiste peut saisir les montants comptes
/// (closingCounted) pour faire apparaitre les ecarts, puis cloturer.
///
/// Les soldes sont stockes en JSON { "USD": "12000.00", "CDF": "250000.00" } :
/// le nombre de devises varie et une table de lignes serait surdimensionnee.
model CashSession {
  id         String            @id @default(uuid()) @db.Uuid
  agencyId   String            @map("agency_id") @db.Uuid
  operatorId String            @map("operator_id") @db.Uuid
  status     CashSessionStatus @default(OUVERTE)

  openingBalances Json  @map("opening_balances")
  closingCounted  Json? @map("closing_counted")

  openedAt DateTime  @default(now()) @map("opened_at")
  closedAt DateTime? @map("closed_at")
  note     String?   @db.Text

  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Restrict)
  operator User   @relation("CashSessionOperator", fields: [operatorId], references: [id], onDelete: Restrict)

  transactions Transaction[]

  /// Un cabiste n'a qu'une seule session ouverte a la fois : garanti par un
  /// index unique partiel (cf. migration) et verifie applicativement.
  @@index([operatorId, status])
  @@index([agencyId, openedAt])
  @@map("cash_sessions")
}

// ---------------------------------------------------------------------------
// Pieces jointes
// ---------------------------------------------------------------------------

model Attachment {
  id            String         @id @default(uuid()) @db.Uuid
  kind          AttachmentKind
  clientId      String?        @map("client_id") @db.Uuid
  transactionId String?        @map("transaction_id") @db.Uuid
  filename      String         @db.VarChar(255)
  /// Cle opaque dans le stockage (disque local ou S3). Jamais exposee au client.
  storageKey    String         @unique @map("storage_key") @db.VarChar(400)
  mimeType      String         @map("mime_type") @db.VarChar(120)
  sizeBytes     Int            @map("size_bytes")
  checksum      String         @db.VarChar(64)
  uploadedById  String         @map("uploaded_by_id") @db.Uuid
  createdAt     DateTime       @default(now()) @map("created_at")

  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  uploadedBy  User         @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: Restrict)

  @@index([clientId])
  @@index([transactionId])
  @@map("attachments")
}

// ---------------------------------------------------------------------------
// Alertes
// ---------------------------------------------------------------------------

model Alert {
  id            String        @id @default(uuid()) @db.Uuid
  type          AlertType
  severity      AlertSeverity @default(MOYENNE)
  status        AlertStatus   @default(OUVERTE)
  message       String        @db.VarChar(500)
  /// Contexte machine : seuil franchi, montants cumules, fenetre glissante...
  context       Json?
  transactionId String?       @map("transaction_id") @db.Uuid
  clientId      String?       @map("client_id") @db.Uuid
  agencyId      String?       @map("agency_id") @db.Uuid
  resolvedById  String?       @map("resolved_by_id") @db.Uuid
  resolvedAt    DateTime?     @map("resolved_at")
  resolution    String?       @db.Text
  createdAt     DateTime      @default(now()) @map("created_at")

  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  client      Client?      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resolvedBy  User?        @relation("AlertResolvedBy", fields: [resolvedById], references: [id], onDelete: Restrict)

  @@index([status, severity])
  @@index([agencyId, createdAt])
  @@index([createdAt])
  @@map("alerts")
}

// ---------------------------------------------------------------------------
// Audit
// ---------------------------------------------------------------------------

/// Journal d'audit. Append-only au niveau applicatif : aucun service n'expose
/// d'update/delete. actorEmail est denormalise pour que la trace survive a
/// l'archivage d'un compte.
model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid
  actorEmail String      @map("actor_email") @db.VarChar(190)
  actorRole  Role?       @map("actor_role")
  action     AuditAction
  /// Nom du modele touche : "Transaction", "User"...
  entity     String      @db.VarChar(60)
  entityId   String?     @map("entity_id") @db.VarChar(64)
  /// Etat avant / apres, expurges des secrets (cf. AuditService.redact).
  before     Json?
  after      Json?
  ip         String?     @db.VarChar(64)
  userAgent  String?     @map("user_agent") @db.VarChar(255)
  createdAt  DateTime    @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([actorId, createdAt])
  @@index([entity, entityId])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// Infrastructure
// ---------------------------------------------------------------------------

/// Compteurs de numerotation. Une ligne par (scope, periode), incrementee sous
/// verrou de ligne pour garantir l'unicite des references sans trou exploitable.
model DocumentSequence {
  id      String @id @default(uuid()) @db.Uuid
  /// "TX" ou "BRD"
  scope   String @db.VarChar(16)
  /// Code agence
  agency  String @db.VarChar(8)
  /// "20260717" pour les transactions, "2026" pour les bordereaux
  period  String @db.VarChar(16)
  current Int    @default(0)

  @@unique([scope, agency, period])
  @@map("document_sequences")
}

/// Parametres systeme modifiables par l'ADMIN sans redeploiement
/// (seuils AML, ecart de taux tolere, duree de session...).
model SystemSetting {
  key         String   @id @db.VarChar(80)
  value       Json
  description String?  @db.VarChar(255)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}
